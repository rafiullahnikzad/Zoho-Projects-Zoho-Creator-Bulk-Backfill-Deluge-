// ════════════════════════════
info "── Fetching page 3 | Index: " + page3_index;
p3_url = "https://projectsapi.zoho.com/restapi/portal/" + portalId + "/projects/?index=" + page3_index + "&range=" + records_per_page;
p3_response = invokeurl
[
