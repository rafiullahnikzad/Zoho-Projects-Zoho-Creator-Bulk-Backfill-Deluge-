// ══════════════════════════════════════════
// ── FINAL SUMMARY ──
// ══════════════════════════════════════════
next_index = start_index + 300;
info "=== BACKFILL BATCH COMPLETE ===";
info "Started at index  : " + start_index;
info "Total fetched     : " + total_fetched;
info "✅ Success        : " + total_success + " (Updates: " + total_update + " | Creates: " + total_create + ")";
info "⏭️ Skipped        : " + total_skip;
info "❌ Errors         : " + total_error;
info "▶️ NEXT RUN → start_index = " + next_index;
}
